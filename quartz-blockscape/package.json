{
  "name": "quartz-blockscape",
  "version": "0.1.0",
  "description": "Quartz v5 transformer plugin for rendering Blockscape maps.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && vite build --config vite.full.config.mjs && tsup && cp dist.README.md dist/README.md",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "quartz",
    "blockscape",
    "plugin"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.2",
    "hast-util-to-html": "^9.0.4",
    "mdast-util-to-hast": "^13.2.0",
    "remark-parse": "^11.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "unified": "^11.0.5",
    "vfile": "^6.0.3",
    "vitest": "^2.1.8",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "svelte": "^4.2.20",
    "vite": "^5.4.21"
  },
  "peerDependencies": {
    "quartz": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "quartz": {
      "optional": true
    }
  }
}
